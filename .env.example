# Optional runtime overrides for invoice-check-cli.
# The wrapper loads this file from services/invoice-check-cli/.env when present.

# Path to adb. On Linux servers install Android platform-tools and set this to
# /usr/bin/adb, /opt/android-platform-tools/adb, or another absolute path.
INVOICE_CHECK_ADB_PATH=adb
INVOICE_CHECK_ADB_SERIAL=

# Module-local queue and phone resource lock. On Linux servers prefer a
# persistent writable path such as /var/lib/agentd-services/invoice-check-cli.
INVOICE_CHECK_RUNTIME_DIR=/tmp/agentd-invoice-check-cli
# INVOICE_CHECK_QUEUE_DB_PATH=/var/lib/agentd-services/invoice-check-cli/queue.sqlite3
INVOICE_CHECK_PHONE_RESOURCE_ID=android_phone:invoice-default
INVOICE_CHECK_PHONE_DISPLAY_NAME=发票查验手机
INVOICE_CHECK_PHONE_LOCK_WAIT_SECONDS=7200
INVOICE_CHECK_QUEUE_WAIT_TIMEOUT_SECONDS=7200
INVOICE_CHECK_MAX_STEPS=30
INVOICE_CHECK_BATCH_ATTEMPTS=1
INVOICE_CHECK_FAILED_REPLAY_ENABLED=false
INVOICE_CHECK_MAX_SAME_STATE_VISITS=3
INVOICE_CHECK_MAX_SAME_ACTION_REPEATS=2
INVOICE_CHECK_MAX_H5_LOADING_WAITS=2
INVOICE_CHECK_QR_PRECHECK_ENABLED=true
INVOICE_CHECK_QR_PRECHECK_BLOCK_UNREADABLE=false
INVOICE_CHECK_QR_PRECHECK_MODE=fast_positive_only
INVOICE_CHECK_QR_CROP_FALLBACK_ENABLED=true
# Optional override; default resolves to ../ocr-cli/bin/ocr-cli.
# INVOICE_CHECK_OCR_CLI_PATH=/opt/agentd-services/ocr-cli/bin/ocr-cli

INVOICE_CHECK_VLM_API=http://127.0.0.1:8081/v1/chat/completions
INVOICE_CHECK_VLM_MODEL=Qwen3.6-35B-A3B-UD-Q4_K_XL.gguf
# Optional for OpenAI-compatible proxies requiring bearer auth.
# INVOICE_CHECK_VLM_API_KEY=
INVOICE_CHECK_VLM_TEMPERATURE=0.01
INVOICE_CHECK_VLM_TOP_P=0.8
INVOICE_CHECK_VLM_TOP_K=20
INVOICE_CHECK_VLM_MAX_TOKENS=512
INVOICE_CHECK_VLM_TIMEOUT=30
INVOICE_CHECK_VLM_ENABLE_THINKING=false

INVOICE_CHECK_PADDLE_VL_API=http://127.0.0.1:8090/v1/chat/completions
INVOICE_CHECK_PADDLE_VL_MODEL=PaddleOCR-VL
# INVOICE_CHECK_PADDLE_VL_API_KEY=
INVOICE_CHECK_PADDLE_VL_TEMPERATURE=0
INVOICE_CHECK_PADDLE_VL_MAX_TOKENS=768
INVOICE_CHECK_PADDLE_VL_TIMEOUT=15

INVOICE_CHECK_REMOTE_DIR=/sdcard/Pictures/invoice-check
INVOICE_CHECK_REMOTE_IMAGE=qr_current.png

# Optional: use a different JSON config file.
# INVOICE_CHECK_CONFIG=/opt/agentd-services/invoice-check-cli/shared/defaults.json
